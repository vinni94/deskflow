# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/deskflow
# Or use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=deskflow
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=3001

# Frontend origin for CORS (in production set to your actual domain)
FRONTEND_ORIGIN=http://localhost:5500
